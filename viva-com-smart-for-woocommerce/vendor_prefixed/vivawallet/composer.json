{
    "name": "vivawallet\/vivawallet-php",
    "description": "Package to handle http requests to Viva Wallet APi for native checkout",
    "version": "2.3.1",
    "type": "library",
    "require": {
        "php": ">=7.3.0",
        "guzzlehttp\/guzzle": "7.10.0",
        "ext-json": "*"
    },
    "require-dev": {
        "friendsofphp\/php-cs-fixer": "v2.19.3",
        "squizlabs\/php_codesniffer": "^3.13.3",
        "phpunit\/phpunit": "9.6.29",
        "phpcompatibility\/php-compatibility": "^10.0.0@dev"
    },
    "license": "GPL-3.0-or-later",
    "homepage": "https:\/\/www.vivawallet.com",
    "minimum-stability": "dev",
    "keywords": [
        "native checkout",
        "payments",
        "Viva Wallet",
        "Vivapayments"
    ],
    "support": {
        "wiki": "https:\/\/developer.vivawallet.com\/"
    },
    "autoload": {
        "psr-4": {
            "VivaComSmartCheckout\\Vivawallet\\VivawalletPhp\\": "lib"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "VivaComSmartCheckout\\Vivawallet\\VivawalletPhp\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "phpunit",
        "compatible:min": "phpcs -ps --standard=PHPCompatibility --runtime-set testVersion 7.3 --runtime-set ignore_warnings_on_exit 1 lib",
        "compatible:80": "phpcs -ps --standard=PHPCompatibility --runtime-set testVersion 8.0 --runtime-set ignore_warnings_on_exit 1 lib",
        "compatible:82": "phpcs -ps --standard=PHPCompatibility --runtime-set testVersion 8.2 --runtime-set ignore_warnings_on_exit 1 lib",
        "compatible:84": "phpcs -ps --standard=PHPCompatibility --runtime-set testVersion 8.4 --runtime-set ignore_warnings_on_exit 1 lib",
        "compatible:range": "phpcs -ps --standard=PHPCompatibility --runtime-set testVersion 7.3-8.4 --runtime-set ignore_warnings_on_exit 1 lib",
        "compatible:range:tests": "phpcs -ps --standard=PHPCompatibility --runtime-set testVersion 7.3-8.4 --runtime-set ignore_warnings_on_exit 1 tests"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect\/phpcodesniffer-composer-installer": true
        }
    }
}